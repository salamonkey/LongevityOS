{
  "schema_version": 1,
  "generated_at_utc": "{{generated_at_utc}}",
  "slice_id": "{{slice_id}}",
  "required_storybook_paths": [],
  "required_components": [],
  "required_screens": [],
  "required_states": ["default", "loading", "empty", "error", "success"],
  "required_statuses": ["done", "due", "soon", "planned", "overdue"],
  "required_priorities": ["today", "soon", "later"],
  "closeout_gate": {
    "required": true,
    "rule": "A slice cannot close until Storybook coverage review status is pass."
  }
}
