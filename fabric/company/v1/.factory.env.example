# Factory-global LLM defaults for all projects using this fabric package.
# Copy this file to:
#   fabric/company/v1/.factory.env
# Runtime behavior:
# - Loaded automatically by fabric runtime at command start.
# - Only fills env vars that are not already set in the shell.
# - Project-level fabric.values.json still takes precedence over env values.

# Enable LLM calls by default for all roles unless overridden per-role.
LLM_ENABLED=true

# Coder role defaults (Codex-compatible source-file authoring).
CODER_LLM_ENABLED=true
CODER_LLM_PROVIDER=stdio_json
CODER_LLM_STDIO_COMMAND=node
CODER_LLM_STDIO_ARGS=fabric/company/v1/runtime/lib/llm/codex-stdio-bridge.mjs
CODER_LLM_TIMEOUT_MS=600000
# Stream raw provider stderr to terminal (Codex progress/details in CLI).
# Set to true when you want VS Code-like visibility during model calls.
CODER_LLM_STDIO_TRACE=false
# Prevent broad app-shell rewrites by default (recommended).
# Set to true only when a slice explicitly requires minimal App-shell integration edits.
CODER_ALLOW_APP_SHELL_MUTATION=false
# Optional: set explicit codex binary path when `codex` is not available in PATH.
# CODEX_BIN=/absolute/path/to/codex

# Optional OpenAI fallback defaults (uncomment if needed).
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.4
# LLM_API_KEY_ENV=OPENAI_API_KEY

# Semantic UX gate defaults.
# The semantic gate runs deterministic scans plus an LLM reviewer before slice closeout.
SEMANTIC_UX_LLM_ENABLED=true
SEMANTIC_UX_LLM_REQUIRED=true
# Prefer UI/UX profile for semantic review when available; otherwise the runtime falls back to review/coder/planning/intake profiles.
# UIUX_LLM_PROVIDER=openai
# UIUX_LLM_MODEL=gpt-5.4
# UIUX_LLM_API_KEY_ENV=OPENAI_API_KEY

# Tester gate defaults (Step 21d).
TESTER_LLM_ENABLED=true
TESTER_LLM_PROVIDER=openai
TESTER_LLM_MODEL=gpt-5.4
TESTER_LLM_API_KEY_ENV=OPENAI_API_KEY
